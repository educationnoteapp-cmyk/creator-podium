# ============================================================
# The Creator Podium — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# OpenAI — used for message moderation before allowing leaderboard posts
OPENAI_API_KEY=sk-...

# Stripe — platform-level keys (used for all charges via Stripe Connect)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Connect OAuth — get from your Stripe Connect settings
# https://dashboard.stripe.com/settings/connect
STRIPE_CLIENT_ID=ca_...

# Single platform webhook secret (one secret for all creator events)
# Register endpoint: /api/webhook/stripe in your Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin panel access (the email address of the admin user)
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# Upstash Redis — distributed rate limiting across serverless instances.
# Get these from your Upstash console: https://console.upstash.com
# Optional: if omitted, rate limiting fails open (requests are allowed).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
